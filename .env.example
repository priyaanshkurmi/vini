# VINI Configuration Example
# Copy this to .env and fill in your actual values

# === LLM Configuration ===
# Choose one: "gemini" or "ollama"
LLM_PROVIDER=gemini

# Gemini API (get from https://aistudio.google.com/app/apikeys)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Ollama settings (if using ollama fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# === Voice & Audio ===
WHISPER_MODEL=base
TTS_MODEL=models/tts/en_US-lessac-medium.onnx

# === Wake Word Detection ===
PICOVOICE_KEY=your_picovoice_access_key_here

# === Memory & Database ===
DB_URL=sqlite:///vini.db
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Server ===
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1

# === Frontend ===
AVATAR_PORT=3000

# === Logging ===
LOG_LEVEL=INFO
LOG_DIR=./logs

# === Security ===
# Comma-separated list of allowed origins (for CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
