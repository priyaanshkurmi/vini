{
  "name": "vini-avatar",
  "version": "1.0.0",
  "description": "Vini holographic desktop avatar",
  "author": "Priyansh Patel",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "build": {
    "appId": "com.priyansh.vini",
    "productName": "VINI",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}